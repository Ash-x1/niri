/* Dark purple + warm yellow theme */

* {
    border: none;
    border-radius: 0;
    font-family:
        "SF Pro Text",
        "Noto Sans",
        "Noto Sans CJK JP",
        "JetBrainsMono Nerd Font",
        sans-serif;
    font-weight: bold;
    font-size: 14px;
    margin: 0;
    padding: 0;
}

window#waybar {
    background-color: #14111f;
    color: #f5e6c8;
    transition-property: background-color;
    transition-duration: 0.1s;
    border-bottom: 2px solid #6d4aff;
}

#window {
    color: #d8c8ff;
    margin: 4px 8px;
    padding-top: 0;
    padding-bottom: 0;
    min-height: 24px;
}

button {
    box-shadow: inset 0 -3px transparent;
}

button:hover {
    background: inherit;
    color: #c792ea;
    border-top: 2px solid #c792ea;
}

#workspaces button {
    padding: 0 10px;
    color: #9f7aea;
    min-height: 24px;
}

#workspaces button.active {
    background-color: rgba(255, 255, 255, 0.08);
    color: #ffd166;
    border-top: 2px solid #ffd166;
}

#workspaces button.urgent {
    background-color: #ff5f87;
    color: #14111f;
}

#pulseaudio,
#clock,
#battery,
#backlight,
#tray,
#language,
#keyboard-state,
#custom-cava,
#custom-swaync {
    margin: 4px 6px;
    padding: 0 8px;
    min-height: 24px;
}

#clock {
    color: #ffd166;
    border-bottom: 2px solid #ffd166;
}

#pulseaudio {
    color: #b084f5;
    border-bottom: 2px solid #b084f5;
}

#backlight {
    color: #f6c177;
    border-bottom: 2px solid #f6c177;
}

#battery {
    color: #c792ea;
    border-bottom: 2px solid #c792ea;
}

#battery.warning {
    color: #ffb703;
}

#battery.critical:not(.charging) {
    color: #ff5f87;
    animation-name: blink;
    animation-duration: 0.5s;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
    animation-direction: alternate;
}

#language {
    color: #e0aaff;
    border-bottom: 2px solid #e0aaff;
}

#custom-cava {
    color: #c77dff;
    border-bottom: 2px solid #c77dff;
}

#custom-swaync {
    color: #9f7aea;
    border-bottom: 2px solid #9f7aea;
}

#tray {
    color: #f5e6c8;
}

@keyframes blink {
    to {
        background-color: #ff5f87;
        color: #14111f;
    }
}
